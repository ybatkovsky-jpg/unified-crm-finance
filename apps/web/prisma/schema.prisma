// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Identity Bounded Context
// ============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  phone        String?
  telegramId   String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  userRoles        UserRole[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  contacts         Contact[]         @relation("ContactOwner")
  deals            Deal[]            @relation("DealManager")
  projects         Project[]         @relation("ProjectManager")
  approvalRequests ApprovalRequest[] @relation("ApprovalRequester")
  approvalDecisions ApprovalRequest[] @relation("ApprovalDecider")
  interactions     Interaction[]     @relation("InteractionAuthor")
  uploadedFiles    FileEntity[]
  comments         Comment[]

  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
}

model Role {
  id          String @id @default(uuid())
  code        String @unique // owner | sales | manager | accountant | storekeeper
  name        String
  description String?
  permissions Json   // array of strings: ["deal:read", "contract:sign", etc.]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserRole[]

  @@index([code])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  entityType String   // contact | deal | contract | project | transaction | ...
  entityId   String
  action     String   // create | update | delete | restore | login | logout | sync
  changes    Json?    // { before: {...}, after: {...} }
  metadata   Json?    // { ip, userAgent, source }
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ============================================================================
// Placeholder relations for entities defined in other bounded contexts
// ============================================================================

model Contact {
  id          String   @id @default(uuid())
  type        String   // person | company
  // Person fields
  firstName   String?
  lastName    String?
  middleName  String?
  // Company fields
  companyName String?
  inn         String?
  kpp         String?
  ogrn        String?
  // Common fields
  email       String?
  phone       String?
  address     String?
  physicalAddress String?
  position    String?  // for person contact at company
  notes       String?
  // Relations
  sourceId    String?  // LeadSource.id
  ownerId     String?  // User.id
  status      String   @default("active") // active | blacklisted | archived
  tags        Json?    @default("[]")  // JSON array for SQLite compatibility
  attributes  Json?    // additional custom fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  owner  User?       @relation("ContactOwner", fields: [ownerId], references: [id])
  source LeadSource? @relation(fields: [sourceId], references: [id])
  leads  Lead[]
  interactions Interaction[]

  @@index([email])
  @@index([phone])
  @@index([inn])
  @@index([ownerId])
  @@index([status])
  @@index([deletedAt])
}

model Deal {
  id        String @id @default(uuid())
  managerId String?

  manager User? @relation("DealManager", fields: [managerId], references: [id])

  @@index([managerId])
}

model Project {
  id        String @id @default(uuid())
  managerId String?

  manager User? @relation("ProjectManager", fields: [managerId], references: [id])

  @@index([managerId])
}

model ApprovalRequest {
  id         String   @id @default(uuid())
  type       String   // purchase | payment | writeoff
  entityId   String
  status     String   @default("pending") // pending | approved | rejected | cancelled
  amount     Float?
  requestedBy String
  decidedBy  String?
  requestedAt DateTime @default(now())
  decidedAt  DateTime?

  requester User? @relation("ApprovalRequester", fields: [requestedBy], references: [id])
  decider   User? @relation("ApprovalDecider", fields: [decidedBy], references: [id])

  @@index([status])
  @@index([requestedBy])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  level     String   @default("info")
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Interaction {
  id          String    @id @default(uuid())
  contactId   String
  type        String    // call | meeting | email | telegram | note | visit
  direction   String?   // incoming | outgoing
  subject     String?
  content     String?
  scheduledAt DateTime?
  completedAt DateTime?
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author  User    @relation("InteractionAuthor", fields: [authorId], references: [id])

  @@index([contactId, completedAt])
  @@index([authorId])
  @@index([scheduledAt])
}

// ============================================================================
// Shared Bounded Context
// ============================================================================

model FileEntity {
  id         String   @id @default(uuid())
  fileName   String
  storageKey String   // S3/MinIO key
  mimeType   String?
  size       Int
  bucket     String   @default("default")
  uploadedBy String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [uploadedBy], references: [id])

  @@index([uploadedBy])
}

model Comment {
  id              String   @id @default(uuid())
  content         String
  authorId        String
  relatedEntityType String  // contact | deal | contract | project | etc.
  relatedEntityId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([relatedEntityType, relatedEntityId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  parentId  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]  @relation("CategoryHierarchy")

  @@index([parentId])
}

// ============================================================================
// CRM Bounded Context
// ============================================================================

model LeadSource {
  id          String    @id @default(uuid())
  code        String    @unique  // call | office | website | email | telegram | referral | other
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  contacts Contact[]
}

model Lead {
  id          String   @id @default(uuid())
  contactId   String
  status      String   @default("new") // new | contacted | qualified | converted | lost
  value       Float?
  currency    String   @default("RUB")
  expectedCloseDate DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([expectedCloseDate])
}
