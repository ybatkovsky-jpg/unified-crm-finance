generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApprovalRequest {
  id                                     String    @id
  type                                   String
  entityId                               String
  status                                 String    @default("pending")
  amount                                 Decimal?  @db.Decimal(15, 2)
  requestedBy                            String
  decidedBy                              String?
  requestedAt                            DateTime  @default(now())
  decidedAt                              DateTime?
  comment                                String?
  User_ApprovalRequest_decidedByToUser   User?     @relation("ApprovalRequest_decidedByToUser", fields: [decidedBy], references: [id])
  User_ApprovalRequest_requestedByToUser User      @relation("ApprovalRequest_requestedByToUser", fields: [requestedBy], references: [id])

  @@index([requestedBy])
  @@index([status])
}

model AuditLog {
  id         String   @id
  userId     String?
  entityType String
  entityId   String
  action     String
  changes    Json?
  metadata   Json?
  createdAt  DateTime @default(now())
  User       User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model AutomationRule {
  id        String    @id
  name      String
  type      String
  enabled   Boolean   @default(false)
  config    Json
  lastRunAt DateTime?
  runCount  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime

  @@index([enabled])
}

model BOM {
  id           String      @id
  projectId    String      @unique
  sourceFileId String?     @unique
  status       String      @default("draft")
  version      Int         @default(1)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  FileEntity   FileEntity? @relation(fields: [sourceFileId], references: [id])
  Project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  BOMItem      BOMItem[]

  @@index([projectId])
}

model BOMItem {
  id                   String                 @id
  bomId                String
  rowNumber            Int
  name                 String
  article              String?
  category             String?
  material             String?
  quantity             Float
  unit                 String                 @default("шт")
  price                Decimal                @default(0) @db.Decimal(15, 2)
  supplierId           String?
  status               String                 @default("pending")
  isFromWarehouse      Boolean                @default(false)
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  Counterparty         Counterparty?          @relation(fields: [supplierId], references: [id])
  BOM                  BOM                    @relation(fields: [bomId], references: [id], onDelete: Cascade)
  InvoiceItem          InvoiceItem[]
  PurchaseRequestItem  PurchaseRequestItem[]
  WarehouseTransaction WarehouseTransaction[]

  @@index([status])
  @@index([supplierId])
  @@index([bomId])
}

/// План по статье и периоду. Проектный бюджет (projectId заполнен) или
/// организационный план постоянных расходов (projectId = null). ACCT-01/03.
/// Для орг-бюджетов уникальность (categoryId + period) обеспечена partial index
/// в миграции (Postgres: NULL не равен NULL в обычном @@unique).
model Budget {
  id         String   @id
  /// null для организационного бюджета (постоянные расходы организации).
  projectId  String?
  categoryId String
  amount     Decimal  @db.Decimal(15, 2)
  period     String
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  Category   Category @relation(fields: [categoryId], references: [id])
  Project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, categoryId, period])
}

model CashFlowPayment {
  id             String        @id
  date           DateTime
  amount         Decimal       @db.Decimal(15, 2)
  type           String
  counterpartyId String?
  projectId      String?
  invoiceId      String?
  description    String?
  status         String        @default("planned")
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  Project        Project?      @relation(fields: [projectId], references: [id])
  Counterparty   Counterparty? @relation(fields: [counterpartyId], references: [id])

  @@index([status, date])
  @@index([projectId, date])
}

model Category {
  id                 String               @id
  name               String
  type               String
  parentId           String?
  order              Int                  @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Budget             Budget[]
  Category           Category?            @relation("CategoryToCategory", fields: [parentId], references: [id])
  other_Category     Category[]           @relation("CategoryToCategory")
  ClassificationRule ClassificationRule[]
  Transaction        Transaction[]

  @@index([parentId])
  @@index([type])
}

model ClassificationRule {
  id                  String   @id
  keyword             String
  categoryId          String
  counterpartyKeyword String?
  projectId           String?
  priority            Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  Category            Category @relation(fields: [categoryId], references: [id])
}

model Comment {
  id                String       @id
  content           String
  authorId          String
  relatedEntityType String
  relatedEntityId   String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  User              User         @relation(fields: [authorId], references: [id])
  FileEntity        FileEntity[]

  @@index([relatedEntityType, relatedEntityId])
  @@index([authorId])
}

model Contact {
  id              String        @id
  type            String
  firstName       String?
  lastName        String?
  middleName      String?
  companyName     String?
  inn             String?
  kpp             String?
  ogrn            String?
  email           String?
  phone           String?
  address         String?
  physicalAddress String?
  position        String?
  notes           String?
  sourceId        String?
  ownerId         String?
  status          String        @default("active")
  tags            Json?         @default("[]")
  attributes      Json?
  /// Паспортные данные (для физлиц) — автоподстановка в договор.
  passportSeries      String?
  passportNumber      String?
  passportIssuedBy    String?
  passportIssuedAt    DateTime?
  passportCode        String?
  registrationAddress String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  deletedAt       DateTime?
  LeadSource      LeadSource?   @relation(fields: [sourceId], references: [id])
  User            User?         @relation(fields: [ownerId], references: [id])
  /// FK на юрлицо — связь физлица с компанией. Только для type='person'.
  companyId       String?
  Company         Contact?      @relation("ContactCompany", fields: [companyId], references: [id])
  Employees       Contact[]     @relation("ContactCompany")
  Contract        Contract[]
  Deal            Deal[]
  DealContact     DealContact[]
  Event           Event[]
  Interaction     Interaction[]
  Lead            Lead[]
  Project         Project[]
  Task            Task[]

  @@index([deletedAt])
  @@index([status])
  @@index([ownerId])
  @@index([inn])
  @@index([phone])
  @@index([email])
  @@index([companyId])
}

model Contract {
  id               String            @id
  number           String            @unique
  dealId           String?           @unique
  contactId        String
  templateId       String?
  title            String
  amount           Decimal           @default(0) @db.Decimal(15, 2)
  currency         String            @default("RUB")
  startDate        DateTime?
  endDate          DateTime?
  signedAt         DateTime?
  status           String            @default("draft")
  signedFileId     String?
  notes            String?
  attributes       Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  FileEntity       FileEntity?       @relation(fields: [signedFileId], references: [id])
  ContractTemplate ContractTemplate? @relation(fields: [templateId], references: [id])
  Contact          Contact           @relation(fields: [contactId], references: [id])
  ContractSigner   ContractSigner[]
  ContractVersion  ContractVersion[]
  Deal             Deal?             @relation(fields: [dealId], references: [id])
  ChangeOrder      ChangeOrder[]

  @@index([dealId])
  @@index([status])
  @@index([contactId])
}

model ContractSigner {
  id              String    @id
  contractId      String
  name            String
  position        String?
  signedAt        DateTime?
  signatureFileId String?
  Contract        Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model ContractTemplate {
  id          String     @id
  code        String     @unique
  name        String
  description String?
  contentMd   String
  variables   Json
  isActive    Boolean    @default(true)
  version     Int        @default(1)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  Contract    Contract[]
}

model ContractVersion {
  id                 String      @id
  contractId         String
  version            Int
  contentMd          String
  generatedPdfFileId String?
  createdBy          String
  createdAt          DateTime    @default(now())
  FileEntity         FileEntity? @relation(fields: [generatedPdfFileId], references: [id])
  Contract           Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, version])
}

model Counterparty {
  id              String            @id
  name            String
  type            String
  types           Json              @default("[]")
  inn             String?
  kpp             String?
  email           String?
  phone           String?
  contactPerson   String?
  address         String?
  bankName        String?
  bankAccount     String?
  korAccount      String?
  bik             String?
  notes           String?
  rating          Int?
  attributes      Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  deletedAt       DateTime?
  BOMItem         BOMItem[]
  CashFlowPayment CashFlowPayment[]
  Delivery        Delivery[]
  EmailLog        EmailLog[]
  Invoice         Invoice[]
  Production      Production[]
  PurchaseRequest PurchaseRequest[]
  Transaction     Transaction[]

  @@index([type])
  @@index([inn])
}

model Deal {
  id                String        @id
  number            String        @unique
  title             String
  pipelineId        String
  stageId           String
  contactId         String?
  amount            Decimal       @default(0) @db.Decimal(15, 2)
  currency          String        @default("RUB")
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  managerId         String?
  description       String?
  lossReason        String?
  sourceId          String?
  attributes        Json?
  /// Адрес объекта, на который делается заказ.
  objectAddress     String?
  contractId        String?       @unique
  projectId         String?       @unique
  drawingFileId     String?
  actFileId         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime
  closedAt          DateTime?
  deletedAt         DateTime?
  ActFile           FileEntity?   @relation("Deal_ActFile", fields: [actFileId], references: [id])
  Contact           Contact?      @relation(fields: [contactId], references: [id])
  DealStage         DealStage     @relation(fields: [stageId], references: [id])
  DrawingFile       FileEntity?   @relation("Deal_DrawingFile", fields: [drawingFileId], references: [id])
  LeadSource        LeadSource?   @relation(fields: [sourceId], references: [id])
  Pipeline          Pipeline      @relation(fields: [pipelineId], references: [id])
  DealHistory       DealHistory[]
  DealContact       DealContact[]
  Event             Event[]
  Task              Task[]
  User              User?         @relation(fields: [managerId], references: [id])
  Contract          Contract?
  Project           Project?

  @@index([projectId])
  @@index([contractId])
  @@index([expectedCloseDate])
  @@index([managerId])
  @@index([stageId])
  @@index([sourceId])
}

/// Связь сделки с контактными лицами по ролям (customer, designer, installer, other).
model DealContact {
  id        String   @id
  dealId    String
  contactId String
  /// customer | designer | installer | other
  role      String
  Deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  Contact   Contact  @relation(fields: [contactId], references: [id])
  createdAt DateTime @default(now())

  @@unique([dealId, contactId, role])
  @@index([dealId])
  @@index([contactId])
}

model DealHistory {
  id          String     @id
  dealId      String
  fromStageId String?
  toStageId   String?
  comment     String?
  changedBy   String
  changedAt   DateTime   @default(now())
  Deal        Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  FromStage   DealStage? @relation("DealHistory_FromStage", fields: [fromStageId], references: [id])
  ToStage     DealStage? @relation("DealHistory_ToStage", fields: [toStageId], references: [id])
  ChangedBy   User       @relation("DealHistory_ChangedBy", fields: [changedBy], references: [id])

  @@index([dealId, changedAt])
}

model DealStage {
  id                    String        @id
  pipelineId            String
  code                  String
  name                  String
  order                 Int
  probability           Float         @default(0)
  isWonStage            Boolean       @default(false)
  isLostStage           Boolean       @default(false)
  color                 String?
  Deal                  Deal[]
  DealHistory_FromStage DealHistory[] @relation("DealHistory_FromStage")
  DealHistory_ToStage   DealHistory[] @relation("DealHistory_ToStage")
  Pipeline              Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, code])
  @@index([pipelineId, order])
}

model Delivery {
  id             String       @id
  projectId      String
  supplierId     String
  invoiceId      String?      @unique
  status         String       @default("pending")
  deliveryType   String?      @default("supplier_to_production")
  trackingNumber String?
  carrier        String?
  fromLocation   String?
  toLocation     String?
  cost           Decimal?     @db.Decimal(15, 2)
  estimatedDate  DateTime?
  actualDate     DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Invoice        Invoice?     @relation(fields: [invoiceId], references: [id])
  Counterparty   Counterparty @relation(fields: [supplierId], references: [id])
  Project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model EmailLog {
  id           String        @id
  projectId    String?
  supplierId   String?
  direction    String
  subject      String
  body         String
  from         String
  to           String
  attachments  Json?
  sentAt       DateTime      @default(now())
  createdAt    DateTime      @default(now())
  Counterparty Counterparty? @relation(fields: [supplierId], references: [id])
  Project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([sentAt])
  @@index([supplierId])
  @@index([projectId])
}

model Event {
  id              String           @id
  googleEventId   String?          @unique
  title           String
  description     String?
  location        String?
  isAllDay        Boolean          @default(false)
  startAt         DateTime
  endAt           DateTime
  status          String           @default("confirmed")
  eventType       String           @default("meeting")
  recurrenceId    String?
  recurrenceRule  String?
  contactId       String?
  projectId       String?
  dealId          String?
  createdBy       String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  deletedAt       DateTime?
  EventRecurrence EventRecurrence? @relation(fields: [recurrenceId], references: [id])
  Deal            Deal?            @relation(fields: [dealId], references: [id])
  Project         Project?         @relation(fields: [projectId], references: [id])
  Contact         Contact?         @relation(fields: [contactId], references: [id])
  EventAttendee   EventAttendee[]
  Interaction     Interaction?

  @@index([deletedAt])
  @@index([projectId])
  @@index([contactId])
  @@index([status])
  @@index([endAt])
  @@index([startAt])
}

model EventAttendee {
  id         String    @id
  eventId    String
  userId     String?
  email      String
  name       String?
  status     String    @default("needs_action")
  responseAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
}

model EventRecurrence {
  id         String    @id
  frequency  String
  interval   Int       @default(1)
  until      DateTime?
  count      Int?
  byDay      String?
  byMonthDay String?
  createdBy  String
  createdAt  DateTime  @default(now())
  Event      Event[]

  @@index([frequency])
}

model FileEntity {
  id                String            @id
  fileName          String
  storageKey        String
  mimeType          String?
  size              Int
  bucket            String            @default("default")
  uploadedBy        String?
  createdAt         DateTime          @default(now())
  BOM               BOM?
  Contract          Contract[]
  ContractVersion   ContractVersion[]
  DealAsActFile     Deal[]            @relation("Deal_ActFile")
  DealAsDrawingFile Deal[]            @relation("Deal_DrawingFile")
  AcceptanceActFile AcceptanceAct?    @relation("AcceptanceAct_ActFile")
  Invoice           Invoice?
  InvoiceAsRawFile  Invoice?          @relation("Invoice_RawFile")
  ProjectAsSpecFile Project[]         @relation("Project_SpecFile")
  BankStatement     BankStatement[]   @relation("BankStatement_SourceFile")
  User              User?             @relation(fields: [uploadedBy], references: [id])
  Comment           Comment[]
  Interaction       Interaction[]

  @@index([uploadedBy])
}

model GoogleAccount {
  id             String    @id
  userId         String
  email          String
  refreshToken   String
  accessToken    String?
  tokenExpiresAt DateTime?
  calendarId     String    @default("primary")
  syncEnabled    Boolean   @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  @@unique([userId, calendarId])
  @@index([userId])
}

model GoogleSyncLog {
  id            String   @id
  accountId     String
  direction     String
  entityType    String
  entityId      String
  googleEventId String?
  status        String
  error         String?
  syncedAt      DateTime @default(now())

  @@index([syncedAt])
  @@index([entityId])
  @@index([accountId])
}

model Interaction {
  id          String       @id
  contactId   String
  type        String
  direction   String?
  subject     String?
  content     String?
  scheduledAt DateTime?
  completedAt DateTime?
  authorId    String
  eventId     String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Event       Event?       @relation(fields: [eventId], references: [id])
  Contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  User        User         @relation(fields: [authorId], references: [id])
  FileEntity  FileEntity[]

  @@index([scheduledAt])
  @@index([authorId])
  @@index([contactId, completedAt])
}

model Invoice {
  id                       String                     @id
  number                   String                     @unique
  projectId                String
  supplierId               String
  purchaseRequestId        String?
  invoiceNumber            String?
  totalAmount              Decimal                    @default(0) @db.Decimal(15, 2)
  status                   String                     @default("received")
  receivedAt               DateTime                   @default(now())
  paidAt                   DateTime?
  dueDate                  DateTime?
  notes                    String?
  sourceFileId             String?                    @unique
  rawText                  String?
  rawFileId                String?                    @unique
  verificationResult       Json?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  Delivery                 Delivery?
  RawFile                  FileEntity?                @relation("Invoice_RawFile", fields: [rawFileId], references: [id])
  FileEntity               FileEntity?                @relation(fields: [sourceFileId], references: [id])
  Counterparty             Counterparty               @relation(fields: [supplierId], references: [id])
  PurchaseRequest          PurchaseRequest?           @relation(fields: [purchaseRequestId], references: [id])
  Project                  Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  InvoiceItem              InvoiceItem[]
  Transaction              Transaction[]
  TransactionMatchingAudit TransactionMatchingAudit[]

  @@index([status])
  @@index([supplierId])
  @@index([projectId])
}

model InvoiceItem {
  id             String   @id
  invoiceId      String
  bomItemId      String?
  name           String
  quantity       Float
  price          Decimal  @default(0) @db.Decimal(15, 2)
  totalPrice     Decimal? @db.Decimal(15, 2)
  isMatch        Boolean  @default(false)
  mismatchReason String?
  BOMItem        BOMItem? @relation(fields: [bomItemId], references: [id])
  Invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Lead {
  id                String    @id
  contactId         String
  status            String    @default("new")
  value             Decimal?  @db.Decimal(15, 2)
  currency          String    @default("RUB")
  expectedCloseDate DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime
  Contact           Contact   @relation(fields: [contactId], references: [id])

  @@index([expectedCloseDate])
  @@index([status])
  @@index([contactId])
}

model LeadSource {
  id          String    @id
  code        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  Contact     Contact[]
  Deal        Deal[]
}

model Notification {
  id         String    @id
  userId     String
  type       String
  title      String
  message    String
  level      String    @default("info")
  link       String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  metadata   Json?
  /// Идемпотентность уведомлений (PLAT-02 IDOR/dedupe fix): непрочитанное с тем же
  /// dedupeKey не дублируется. null для уведомлений без идемпотентности.
  dedupeKey  String?
  createdAt  DateTime  @default(now())
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, isRead])
  @@index([userId, dedupeKey, isRead])
}

model PeriodClose {
  id         String   @id
  period     String   @unique
  closedBy   String
  closedAt   DateTime @default(now())
  note       String?
  isReopened Boolean  @default(false)
}

model Pipeline {
  id          String      @id
  code        String      @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  Deal        Deal[]
  DealStage   DealStage[]

  @@index([isActive])
}

model Project {
  id                   String                 @id
  externalNumber       String                 @unique
  name                 String
  description          String?
  dealId               String?                @unique
  contractId           String?                @unique
  contactId            String?
  specFileId           String?
  status               String                 @default("lead")
  contractAmount       Decimal                @default(0) @db.Decimal(15, 2)
  currency             String                 @default("RUB")
  startDate            DateTime?
  endDate              DateTime?
  completedAt          DateTime?
  marginTarget         Float                  @default(0.25)
  qualityRating        String?
  deadlineStatus       String                 @default("on_track")
  managerId            String?
  attributes           Json?
  /// Дата начала гарантийного срока (проставляется при закрытии проекта). PROJ-14.
  warrantyStartDate    DateTime?
  /// Дата окончания гарантии (completedAt + 2 года). PROJ-14.
  warrantyEndDate      DateTime?
  /// Заметка по гарантии, напр. «фурнитура — по гарантии производителя». PROJ-14.
  warrantyNotes        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  deletedAt            DateTime?
  BOM                  BOM?
  Budget               Budget[]
  CashFlowPayment      CashFlowPayment[]
  Delivery             Delivery[]
  EmailLog             EmailLog[]
  Event                Event[]
  Invoice              Invoice[]
  SpecFile             FileEntity?            @relation("Project_SpecFile", fields: [specFileId], references: [id])
  User                 User?                  @relation(fields: [managerId], references: [id])
  Contact              Contact?               @relation(fields: [contactId], references: [id])
  ProjectMember        ProjectMember[]
  ProjectStage         ProjectStage[]
  Production           Production?
  Installation         Installation[]
  ChangeOrder          ChangeOrder[]
  PurchaseRequest      PurchaseRequest[]
  Task                 Task[]
  Transaction          Transaction[]
  ProjectPayment       ProjectPayment[]
  ProjectStatusHistory ProjectStatusHistory[]
  Deal                 Deal?                  @relation(fields: [dealId], references: [id])
  AcceptanceAct        AcceptanceAct?
  DesignerBonus        DesignerBonus?

  @@index([contractId])
  @@index([dealId])
  @@index([managerId])
  @@index([status])
}

/// Акт приёмки выполненных работ по проекту (PROJ-12).
/// Тип подписанта определяется по типу контрагента:
/// физлицо → монтажник подписывает на объекте; юрлицо → менеджер (ЭДО/бумага).
model AcceptanceAct {
  id         String      @id
  projectId  String      @unique
  number     Int
  /// draft | signed
  status     String      @default("draft")
  /// individual (физлицо, подпись монтажника) | legal (юрлицо, подпись менеджера)
  signerType String?
  signedById String?
  signedAt   DateTime?
  /// paper | edo
  signMethod String?
  actFileId  String?     @unique
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime
  Project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  SignedBy   User?       @relation("AcceptanceAct_SignedBy", fields: [signedById], references: [id])
  ActFile    FileEntity? @relation("AcceptanceAct_ActFile", fields: [actFileId], references: [id])

  @@index([projectId])
  @@index([status])
}

/// Бонус дизайнеру по проекту (минимальный след для PROJ-13; полная логика выплат/долга — FIN-06, Phase 8).
model DesignerBonus {
  id         String    @id
  projectId  String    @unique
  designerId String?
  percent    Float     @default(0.1)
  amount     Decimal   @default(0) @db.Decimal(15, 2)
  /// pending | paid
  status     String    @default("pending")
  paidAt     DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  Project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Designer   User?     @relation("DesignerBonus_Designer", fields: [designerId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([designerId])
}

model ProjectMember {
  id        String    @id
  projectId String
  userId    String
  role      String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  User      User      @relation(fields: [userId], references: [id])
  Project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectStage {
  id          String    @id
