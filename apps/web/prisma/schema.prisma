  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
}

model Role {
  id          String     @id
  code        String     @unique
  name        String
  description String?
  permissions Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  UserRole    UserRole[]

  @@index([code])
}

model Setting {
  id    String @id
  key   String @unique
  value String
  type  String @default("string")
}

model SyncLog {
  id            String    @id
  source        String
  status        String
  recordsTotal  Int       @default(0)
  recordsSynced Int       @default(0)
  errors        String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([startedAt])
  @@index([status])
  @@index([source])
}

/// Задача (выезд замер#1/#2/монтаж или общая). PLAT-01.
/// status: todo | in_progress | done | failed | cancelled (контролируется в коде).
/// type: measurement_1 | measurement_2 | installation | general | client.
/// Перенос/пересоздание при неудаче: originalTaskId (корень цепочки),
/// parentTaskId (предыдущая задача при переносе), failedReason.
model Task {
  id                         String    @id
  title                      String
  description                String?
  type                       String    @default("client")
  status                     String    @default("todo")
  priority                   String    @default("medium")
  dueDate                    DateTime?
  completedAt                DateTime?
  contactId                  String?
  projectId                  String?
  dealId                     String?
  assigneeId                 String?
  /// Корень цепочки переноса/пересоздания (первоисточник).
  originalTaskId             String?
  /// Предыдущая задача в цепочке переноса.
  parentTaskId               String?
  /// Почему провалена (клиент не явился, нет доступа и т.п.).
  failedReason               String?
  /// PLAT-06: шаблон-источник, если задача — инстанс орг-шаблона.
  templateId                 String?
  /// PLAT-06: плановая дата инстанса (для идемпотентности материализации).
  plannedDate                DateTime?
  /// PLAT-06: функция компании, к которой привязана орг-задача.
  orgFunctionId              String?
  createdBy                  String
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime
  deletedAt                  DateTime?
  User_Task_createdByToUser  User      @relation("Task_createdByToUser", fields: [createdBy], references: [id])
  User_Task_assigneeIdToUser User?     @relation("Task_assigneeIdToUser", fields: [assigneeId], references: [id])
  Deal                       Deal?     @relation(fields: [dealId], references: [id])
  Project                    Project?  @relation(fields: [projectId], references: [id])
  Contact                    Contact?  @relation(fields: [contactId], references: [id])
  OriginalTask               Task?     @relation("TaskLineage", fields: [originalTaskId], references: [id])
  ParentTask                 Task?     @relation("TaskReschedule", fields: [parentTaskId], references: [id])
  /// PLAT-06: шаблон, породивший инстанс (null для проектных/разовых задач).
  TaskTemplate               TaskTemplate? @relation(fields: [templateId], references: [id])
  /// PLAT-06: функция компании, к которой привязана орг-задача.
  OrgFunction                OrgFunction?  @relation(fields: [orgFunctionId], references: [id])
  Other_Task_OriginalTask    Task[]    @relation("TaskLineage")
  Other_Task_ParentTask      Task[]    @relation("TaskReschedule")

  @@index([deletedAt])
  @@index([projectId])
  @@index([dealId])
  @@index([contactId])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([priority])
  @@index([status])
  @@index([type])
  @@index([originalTaskId])
  @@index([parentTaskId])
  @@index([templateId, plannedDate])
  @@index([orgFunctionId])
}

/// PLAT-06: Отдел компании (Продажи, Производство, Закупки/Склад, Финансы...).
/// Верхний уровень орг-иерархии; внутри — OrgFunction.
model Department {
  id          String      @id
  name        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  deletedAt   DateTime?
  OrgFunction OrgFunction[]

  @@index([deletedAt])
}

/// PLAT-06: Функция компании (реклама, налоги, аренда, инвентаризация...).
/// Принадлежит отделу; на функцию назначаются люди (FunctionAssignment),
/// у функции есть задачи/шаблоны (TaskTemplate, Task).
model OrgFunction {
  id               String             @id
  departmentId     String
  name             String
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  deletedAt        DateTime?
  Department       Department         @relation(fields: [departmentId], references: [id])
  FunctionAssignment FunctionAssignment[]
  TaskTemplate     TaskTemplate[]
  Task             Task[]

  @@unique([departmentId, name])
  @@index([departmentId, deletedAt])
  @@index([deletedAt])
}

/// PLAT-06: Назначение человека на функцию.
/// role: 'head' (руководитель функции, видит все задачи функции) | 'responsible' (исполнитель).
/// Один человек может иметь несколько функций (несколько строк).
model FunctionAssignment {
  id         String     @id
  functionId String
  userId     String
  /// 'head' | 'responsible' (контролируется в коде).
  role       String     @default("responsible")
  createdAt  DateTime   @default(now())
  OrgFunction OrgFunction @relation(fields: [functionId], references: [id], onDelete: Cascade)
  User       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([functionId, userId, role])
  @@index([functionId])
  @@index([userId])
}

/// PLAT-06: Шаблон задачи функции — разовой (rrule = null) или повторяющейся (RFC-5545 rrule).
/// Из шаблона материализуются инстансы Task при наступлении срока (лениво).
model TaskTemplate {
  id                String   @id
  /// null = общая задача без привязки к функции.
  functionId        String?
  title             String
  description       String?
  priority          String   @default("medium")
  /// RFC-5545 строка (FREQ=MONTHLY;BYMONTHDAY=25;...); null = разовая задача.
  rrule             String?
  /// Начало отсчёта рекурренции / срок для разовой задачи.
  dtStart           DateTime
  /// until: конец рекурренции (null = бессрочно).
  dtEnd             DateTime?
  isActive          Boolean  @default(true)
  /// function_responsible | function_head | fixed | unassigned (контролируется в коде).
  assigneeStrategy  String   @default("function_responsible")
  fixedAssigneeId   String?
  createdBy         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  deletedAt         DateTime?
  OrgFunction       OrgFunction? @relation(fields: [functionId], references: [id])
  User_TaskTemplate_createdByToUser   User   @relation("TaskTemplate_createdByToUser", fields: [createdBy], references: [id])
  User_TaskTemplate_fixedAssigneeToUser User? @relation("TaskTemplate_fixedAssigneeToUser", fields: [fixedAssigneeId], references: [id])
  Task              Task[]

  @@index([functionId])
  @@index([isActive])
  @@index([deletedAt])
}

model Transaction {
  id             String          @id
  projectId      String?
  categoryId     String
  counterpartyId String?
  invoiceId      String?
  createdBy      String
  date           DateTime
  amount         Decimal         @db.Decimal(15, 2)
  type           String
  description    String?
  source         String          @default("manual")
  externalId     String?
  status         String          @default("confirmed")
  /// Способ оплаты: cash | bank | card. FIN-03.
  paymentMethod  String?
  /// Тип платежа клиента: prepayment | final | other (связь с этапом 70/30). FIN-01.
  paymentType    String?
  fileIds        Json            @default("[]")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  deletedAt      DateTime?
  Invoice        Invoice?        @relation(fields: [invoiceId], references: [id])
  Counterparty   Counterparty?   @relation(fields: [counterpartyId], references: [id])
  Category       Category        @relation(fields: [categoryId], references: [id])
  Project        Project?        @relation(fields: [projectId], references: [id])
  ProjectPayment ProjectPayment?

  @@unique([externalId, source, date])
  @@index([invoiceId])
  @@index([source])
  @@index([type, date])
  @@index([categoryId])
  @@index([projectId, date])
  @@index([paymentMethod])
}

/// Этап оплаты клиента по проекту (FIN-01: предоплата 70% + финал 30%).
/// Связан с фактическим платежом через Transaction.
model ProjectPayment {
  id             String       @id
  projectId      String
  /// prepayment | final | other
  paymentType    String
  plannedPercent Float
  plannedAmount  Decimal      @default(0) @db.Decimal(15, 2)
  receivedAmount Decimal      @default(0) @db.Decimal(15, 2)
  /// cash | bank | card (способ последнего платежа)
  paymentMethod  String?
  transactionId  String?      @unique
  /// planned | partial | paid
  status         String       @default("planned")
  dueDate        DateTime?
  receivedAt     DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  Project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  Transaction    Transaction? @relation(fields: [transactionId], references: [id])

  @@index([projectId])
  @@index([status])
}

model User {
  id                                                String                 @id
  email                                             String                 @unique
  name                                              String
  passwordHash                                      String
  phone                                             String?
  telegramId                                        String?
  avatarUrl                                         String?
  isActive                                          Boolean                @default(true)
  lastLoginAt                                       DateTime?
  createdAt                                         DateTime               @default(now())
  updatedAt                                         DateTime
  deletedAt                                         DateTime?
  ApprovalRequest_ApprovalRequest_decidedByToUser   ApprovalRequest[]      @relation("ApprovalRequest_decidedByToUser")
  ApprovalRequest_ApprovalRequest_requestedByToUser ApprovalRequest[]      @relation("ApprovalRequest_requestedByToUser")
  AuditLog                                          AuditLog[]
  Comment                                           Comment[]
  Contact                                           Contact[]
  Deal                                              Deal[]
  FileEntity                                        FileEntity[]
  Interaction                                       Interaction[]
  Notification                                      Notification[]
  Project                                           Project[]
  ProjectMember                                     ProjectMember[]
  ProjectStatusHistory                              ProjectStatusHistory[] @relation("User_StatusChanges")
  RefreshToken                                      RefreshToken[]
  Task_Task_createdByToUser                         Task[]                 @relation("Task_createdByToUser")
  Task_Task_assigneeIdToUser                        Task[]                 @relation("Task_assigneeIdToUser")
  DealHistory_ChangedBy                             DealHistory[]          @relation("DealHistory_ChangedBy")
  InstallationWorker                                InstallationWorker[]
  AcceptanceAct_SignedBy                            AcceptanceAct[]        @relation("AcceptanceAct_SignedBy")
  DesignerBonus_Designer                            DesignerBonus[]        @relation("DesignerBonus_Designer")
  UserRole                                          UserRole[]
  /// PLAT-06: назначения на функции компании (одно лицо → несколько функций).
  FunctionAssignment                                FunctionAssignment[]
  /// PLAT-06: созданные шаблоны задач.
  TaskTemplate_TaskTemplate_createdByToUser         TaskTemplate[]         @relation("TaskTemplate_createdByToUser")
  /// PLAT-06: шаблоны, где пользователь — фиксированный исполнитель.
  TaskTemplate_TaskTemplate_fixedAssigneeToUser     TaskTemplate[]         @relation("TaskTemplate_fixedAssigneeToUser")

  @@index([deletedAt])
  @@index([isActive])
  @@index([email])
}

model UserRole {
  userId String
  roleId String
  Role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([userId])
}

model WarehouseItem {
  id                   String                 @id
  name                 String
  article              String?
  category             String?
  quantity             Float                  @default(0)
  reservedQty          Float                  @default(0)
  availableQty         Float                  @default(0)
  minQuantity          Float                  @default(0)
  unit                 String                 @default("шт")
  location             String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  WarehouseTransaction WarehouseTransaction[]

  @@index([name])
  @@index([article])
}

model WarehouseTransaction {
  id              String        @id
  warehouseItemId String
  bomItemId       String?
  type            String
  quantity        Float
  notes           String?
  createdAt       DateTime      @default(now())
  BOMItem         BOMItem?      @relation(fields: [bomItemId], references: [id])
  WarehouseItem   WarehouseItem @relation(fields: [warehouseItemId], references: [id], onDelete: Cascade)

  @@index([warehouseItemId])
}

/// Выписка банка, загруженная как файл/парсинг (zakuppro: bank statement import).
model BankStatement {
  id              String            @id
  accountNumber   String?
  statementDate   DateTime
  periodFrom      DateTime?
  periodTo        DateTime?
  currency        String            @default("RUB")
  totalIncome     Decimal           @default(0) @db.Decimal(15, 2)
  totalExpense    Decimal           @default(0) @db.Decimal(15, 2)
  sourceFileId    String?
  status          String            @default("parsed")
  parsedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  FileEntity      FileEntity?       @relation("BankStatement_SourceFile", fields: [sourceFileId], references: [id])
  BankTransaction BankTransaction[]

  @@index([statementDate])
  @@index([status])
}

/// Движение по счёту из выписки. Отдельно от Transaction (другой lifecycle/constraints,
/// поступает извне, матчится к Invoice/Transaction позже).
model BankTransaction {
  id                       String                     @id
  statementId              String
  transactionDate          DateTime
  amount                   Decimal                    @db.Decimal(15, 2)
  direction                String
  counterpartyName         String?
  counterpartyInn          String?
  counterpartyAccount      String?
  description              String?
  paymentPurpose           String?
  matchingStatus           String                     @default("unmatched")
  externalId               String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  BankStatement            BankStatement              @relation(fields: [statementId], references: [id], onDelete: Cascade)
  TransactionMatchingAudit TransactionMatchingAudit[]
  UnresolvedTransaction    UnresolvedTransaction[]

  @@index([statementId])
  @@index([transactionDate])
  @@index([matchingStatus])
  @@index([counterpartyInn])
}

/// Аудит сопоставления движения по выписке с Invoice (AI/правило/ручное).
model TransactionMatchingAudit {
  id                String          @id
  bankTransactionId String
  invoiceId         String?
  confidenceScore   Decimal         @db.Decimal(15, 2)
  method            String
  decision          String          @default("auto")
  matchedBy         String?
  notes             String?
  createdAt         DateTime        @default(now())
  BankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  Invoice           Invoice?        @relation(fields: [invoiceId], references: [id])

  @@index([bankTransactionId])
  @@index([invoiceId])
  @@index([decision])
}

/// Движение по выписке, которое не удалось размечнуть — очередь ручного разбора.
model UnresolvedTransaction {
  id                String          @id
  bankTransactionId String
  amount            Decimal         @db.Decimal(15, 2)
  reason            String?
  attempts          Int             @default(0)
  status            String          @default("open")
  resolvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  BankTransaction   BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@index([bankTransactionId])
  @@index([status])
}

/// DLQ фоновых задач (Celery в zakuppro: AI-парсинг, email, telegram) — хранение упавших задач для повтора/разбора.
model FailedTask {
  id            String    @id
  taskType      String
  taskName      String?
  payload       Json
  error         String?
  errorTrace    String?
  attempts      Int       @default(0)
  status        String    @default("pending")
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([status])
  @@index([taskType])
  @@index([nextRetryAt])
}

/// История смены статусов проекта (production-трекинг zakuppro).
model ProjectStatusHistory {
  id          String   @id
  projectId   String
  fromStatus  String?
  toStatus    String
  changedById String?
  reason      String?
  changedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  Project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User        User?    @relation("User_StatusChanges", fields: [changedById], references: [id])

  @@index([projectId, changedAt])
}
