# =====================================================================
# Unified CRM Finance — переменные окружения
# Скопируйте этот файл в .env и заполните реальные значения.
# ВНИМАНИЕ: .env никогда не коммитится в репозиторий.
# =====================================================================

# --- Application ---
NODE_ENV=development
APP_NAME=unified-crm-finance
APP_VERSION=0.1.0
# URL приложения (без слеша в конце)
APP_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
# Используется и Next.js (через Prisma) и Python-воркером (через SQLAlchemy)
DATABASE_URL=postgresql://unified:unified_password@localhost:5432/unified_crm?schema=public
# Для Python (sync driver)
DATABASE_URL_SYNC=postgresql+psycopg2://unified:unified_password@localhost:5432/unified_crm
# Для Python (async driver)
DATABASE_URL_ASYNC=postgresql+asyncpg://unified:unified_password@localhost:5432/unified_crm

# Пользователь с ограниченными правами для Python-воркера
WORKER_DB_URL=postgresql://worker:worker_password@localhost:5432/unified_crm

# --- NextAuth (аутентификация) ---
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_random_32_byte_secret
NEXTAUTH_URL=http://localhost:3000
# Время жизни access-токена (секунды) — 15 минут
JWT_ACCESS_TTL=900
# Время жизни refresh-токена (секунды) — 7 дней
JWT_REFRESH_TTL=604800

# --- RabbitMQ (брокер для Celery) ---
RABBITMQ_URL=amqp://unified:unified_password@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# --- Object Storage (MinIO / S3) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=unified_minio
S3_SECRET_KEY=unified_minio_secret
S3_BUCKET=unified-crm
# Использовать path-style (для MinIO); для AWS S3 = false
S3_FORCE_PATH_STYLE=true

# --- Internal webhook secret (между Next.js и Python) ---
# Сгенерировать: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET=replace_me_with_random_hex_32

# --- Python worker ---
WORKER_HOST=localhost
WORKER_PORT=8000
WORKER_URL=http://localhost:8000

# --- LLM providers (для AI-агента, опционально до S7) ---
# Multi-LLM wrapper с fallback: первый рабочий используется
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
# Модель по умолчанию
LLM_DEFAULT_MODEL=deepseek-chat

# --- Email (IMAP/SMTP для приёма счетов и отправки запросов) ---
# SMTP (отправка)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=email@example.com
SMTP_FROM_NAME=Unified CRM
# IMAP (приём)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
# Опрос IMAP каждые N минут (по умолчанию 15)
IMAP_POLL_INTERVAL_MIN=15

# --- Telegram bot (опционально до S11) ---
TELEGRAM_BOT_TOKEN=
# Список разрешённых chatId через запятую
TELEGRAM_ALLOWED_USERS=

# --- Monitoring (опционально) ---
SENTRY_DSN=
LOG_LEVEL=info  # debug | info | warn | error

# --- Rate limiting ---
RATE_LIMIT_PER_MIN=100
RATE_LIMIT_AUTH_PER_MIN=5

# --- File upload limits ---
MAX_UPLOAD_SIZE_MB=50
MAX_EXCEL_SIZE_MB=10
MAX_PDF_SIZE_MB=50
